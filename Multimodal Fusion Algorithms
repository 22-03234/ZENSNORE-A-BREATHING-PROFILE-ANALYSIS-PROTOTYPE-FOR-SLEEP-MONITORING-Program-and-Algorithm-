%% ------------------------------------------------------------
% NIGHT-LEVEL SUMMARY + INTERPRETATION
%% ------------------------------------------------------------
nEpochs = height(T);
nNormal = sum(T.FinalLabel == "Normal");
nSnoring = sum(T.FinalLabel == "Snoring");
nApnea = sum(T.FinalLabel == "SuspectedApnea");
pctNormal  = 100*nNormal/max(nEpochs,1);
pctSnoring = 100*nSnoring/max(nEpochs,1);
pctApnea   = 100*nApnea/max(nEpochs,1);
pctFlowReduced = 100*mean(T.AirflowHasFlowReduced);
pctAirflowApneaLike = 100*mean(T.AirflowHasApneaLike);
pctSoundApneaLike = 100*mean(T.SoundHasApneaLike);
pctHeavySnoring = 100*mean(T.FinalSnoreSeverity == "HeavySnoring");
pctModerateSnoring = 100*mean(T.FinalSnoreSeverity == "ModerateSnoring");
pctSpO2Validated = 100*mean(T.SpO2Validator_any);
pctHRValidated = 100*mean(T.HRValidatorStrict);
NightLabel = "";
NightInterpretation = "";
if pctApnea >= 15
   if pctSnoring >= 20
       NightLabel = "ApneaSuspiciousMixedPattern";
       NightInterpretation = "Apnea-suspicious mixed respiratory pattern";
   else
       NightLabel = "ApneaDominantPattern";
       NightInterpretation = "Apnea-dominant respiratory disturbance pattern";
   end
elseif pctApnea >= 5
   if pctSnoring >= 25 && pctFlowReduced >= 20
       NightLabel = "SnoringDominantHypopneaLikePattern";
       NightInterpretation = "Snoring-dominant hypopnea-like pattern with recurrent airflow reduction";
   elseif pctSnoring >= 25
       NightLabel = "SnoringDominantWithIntermittentApneaSuspicion";
       NightInterpretation = "Snoring-dominant pattern with intermittent apnea-like events";
   else
       NightLabel = "MildApneaSuspiciousPattern";
       NightInterpretation = "Mild apnea-suspicious pattern";
   end
else
   if pctSnoring >= 30 && pctFlowReduced >= 20
       NightLabel = "SnoringDominantWithFlowReduction";
       NightInterpretation = "Snoring-dominant pattern with recurrent airflow reduction";
   elseif pctSnoring >= 30
       NightLabel = "SnoringDominantPattern";
       NightInterpretation = "Snoring-dominant breathing pattern";
   elseif pctFlowReduced >= 20
