%% ============================================================
%  ZENSNORE FINAL MULTIMODAL FUSION + INTERPRETATION + GRAPHS
%  LOCKED VERSION (STRICT VALIDATORS + 3-MIN RELEVANT WINDOW)
%
%  FINAL MAIN LABELS:
%     Normal
%     Snoring
%     SuspectedApnea
%
%  ALSO PRESERVES:
%     - Airflow detail
%     - Sound detail
%     - SpO2 detail
%     - HR detail
%     - Per-epoch detailed fusion tag
%     - Night-level interpretation
%
%  OUTPUTS:
%     fusion_outputs/zensnore_fused_epoch_table.csv
%     fusion_outputs/zensnore_night_summary.csv
%     fusion_outputs/zensnore_most_relevant_window.csv
%     fusion_outputs/fusion_relevant_window_overview.png
%     fusion_outputs/fusion_relevant_window_airflow.png
%     fusion_outputs/fusion_relevant_window_sound.png
%     fusion_outputs/fusion_relevant_window_spo2.png
%     fusion_outputs/fusion_relevant_window_hr.png
%% ============================================================
clc;
clear;
close all;
fprintf('\n============================================================\n');
fprintf(' ZENSNORE FINAL MULTIMODAL FUSION + INTERPRETATION + GRAPHS\n');
fprintf('============================================================\n');
%% ------------------------------------------------------------
% SETTINGS
%% ------------------------------------------------------------
epochLen_sec = 30;
zoomWin_sec  = 180;   % 3 minutes
minFinalQualityToTrust = 0.50; %#ok<NASGU>  % reserved for future extension
% Input files
airflowEpochFile = fullfile(pwd,'airflow_outputs','airflow_epoch_final_classification.csv');
airflowTraceFile = fullfile(pwd,'airflow_outputs','airflow_signal_trace.csv');
soundEpochFile   = fullfile(pwd,'sound_outputs','sound_epoch_final_classification.csv');
soundWindowFile  = fullfile(pwd,'sound_outputs','sound_window_features.csv');
spo2FinalFile    = fullfile(pwd,'spo2_outputs','spo2_epoch_final_classification.csv');
spo2CtxFile      = fullfile(pwd,'spo2_outputs','spo2_contextual_epoch_flags.csv');
spo2RawFile      = fullfile(pwd,'spo2_outputs','spo2_recomputed_from_raw.csv');
spo2CleanFile    = fullfile(pwd,'spo2_outputs','spo2_final_artifact_rejected.csv');
hrEpochFile      = fullfile(pwd,'hr_outputs','hr_epoch_classification.csv');
hrCtxFile        = fullfile(pwd,'hr_outputs','hr_contextual_epoch_flags.csv');
hrProcFile       = fullfile(pwd,'hr_outputs','ppg_hr_processed.csv');
hrTraceFile      = fullfile(pwd,'hr_outputs','ppg_hr_trace.csv');
rawAirflowFile   = fullfile(pwd,'airflow.csv');
rawPPGFile       = fullfile(pwd,'ppg.csv');
rawAudioFile     = fullfile(pwd,'audio.wav');
rawAudio1File    = fullfile(pwd,'audio1.wav');
rawAudio2File    = fullfile(pwd,'audio2.wav');
outDir = fullfile(pwd,'fusion_outputs');
if ~exist(outDir,'dir')
   mkdir(outDir);
end
%% ------------------------------------------------------------
% CHECK REQUIRED FILES
%% ------------------------------------------------------------
requiredFiles = {airflowEpochFile, soundEpochFile, spo2FinalFile, hrEpochFile, hrCtxFile};
for i = 1:numel(requiredFiles)
   if ~isfile(requiredFiles{i})
       error('Required file not found: %s', requiredFiles{i});
   end
end
%% ------------------------------------------------------------
% LOAD TABLES
%% ------------------------------------------------------------
A  = readtable(airflowEpochFile);
S  = readtable(soundEpochFile);
O  = readtable(spo2FinalFile);
H  = readtable(hrEpochFile);
HC = readtable(hrCtxFile);
if isfile(spo2CtxFile)
   OC = readtable(spo2CtxFile);
else
   OC = table();
end
fprintf('\nRows loaded:\n');
fprintf(' Airflow : %d\n', height(A));
fprintf(' Sound   : %d\n', height(S));
fprintf(' SpO2    : %d\n', height(O));
fprintf(' HR      : %d\n', height(H));
fprintf(' HR ctx  : %d\n', height(HC));
%% ------------------------------------------------------------
% STANDARDIZE AIRFLOW TABLE
%% ------------------------------------------------------------
TA = table();
TA.Epoch = getNumericCol(A, {'Epoch'});
TA.StartTime_s = getNumericColOrDefault(A, {'StartTime_s','EpochStart_sec'}, (TA.Epoch-1)*epochLen_sec);
TA.EndTime_s   = getNumericColOrDefault(A, {'EndTime_s','EpochEnd_sec'}, TA.StartTime_s + epochLen_sec);
TA.AirflowClass = getStringCol(A, {'FinalClass','Class'}, "Unknown");
TA.AirflowReason = getStringCol(A, {'Reason'}, "");
TA.AirflowHasApneaEvent = getLogicalColOrDefault(A, {'HasApneaEvent'}, false(height(A),1));
TA.AirflowNumApneaEvents = getNumericColOrDefault(A, {'NumApneaEvents'}, zeros(height(A),1));
TA.AirflowApneaOverlap_s = getNumericColOrDefault(A, {'ApneaOverlap_s'}, zeros(height(A),1));
TA.RMS_kPa            = getNumericColOrDefault(A, {'RMS_kPa'}, nan(height(A),1));
TA.LocalRange_kPa     = getNumericColOrDefault(A, {'LocalRange_kPa'}, nan(height(A),1));
TA.EnvelopeMean_kPa   = getNumericColOrDefault(A, {'EnvelopeMean_kPa'}, nan(height(A),1));
TA.RespiratoryRate_bpm = getNumericColOrDefault(A, {'RespiratoryRate_bpm'}, nan(height(A),1));
TA.AirflowHasFlowReduced = TA.AirflowClass == "FlowReduced";
TA.AirflowHasApneaLike   = TA.AirflowClass == "ApneaLike" | TA.AirflowHasApneaEvent;
%% ------------------------------------------------------------
% STANDARDIZE SOUND TABLE
%% ------------------------------------------------------------
TS = table();
TS.Epoch = getNumericCol(S, {'Epoch','epoch'});
TS.StartTime_s = getNumericColOrDefault(S, {'StartTime_s','epoch_start'}, (TS.Epoch-1)*epochLen_sec);
TS.EndTime_s   = getNumericColOrDefault(S, {'EndTime_s','epoch_end'}, TS.StartTime_s + epochLen_sec);
TS.FinalSnoreSeverity = getStringCol(S, {'FinalSnoreSeverity','AcousticSeverity','label'}, "Normal");
TS.FinalSoundBinary   = getStringCol(S, {'FinalSoundClassBinary','label'}, "Normal");
TS.SnoreCount            = getNumericColOrDefault(S, {'SnoreCount'}, zeros(height(S),1));
TS.SnoreDuration_sec     = getNumericColOrDefault(S, {'SnoreDuration_sec'}, zeros(height(S),1));
TS.SnoreBurden_pct       = getNumericColOrDefault(S, {'SnoreBurden_pct'}, zeros(height(S),1));
TS.SoftSnoreCount        = getNumericColOrDefault(S, {'SoftSnoreCount'}, zeros(height(S),1));
TS.ModerateSnoreCount    = getNumericColOrDefault(S, {'ModerateSnoreCount'}, zeros(height(S),1));
TS.StrongSnoreCount      = getNumericColOrDefault(S, {'StrongSnoreCount'}, zeros(height(S),1));
TS.NoisyBreathingDuration_s = getNumericColOrDefault(S, {'NoisyBreathingDuration_s'}, zeros(height(S),1));
TS.SoundHasSnore = getLogicalColOrDefault(S, {'IsSnoring'}, TS.FinalSoundBinary == "Snoring");
TS.SoundHasApneaLike = getLogicalColOrDefault(S, {'HasApneaLikeSound'}, false(height(S),1));
TS.NumApneaLikeEvents = getNumericColOrDefault(S, {'NumApneaLikeEvents'}, zeros(height(S),1));
TS.ApneaLikeOverlap_s = getNumericColOrDefault(S, {'ApneaLikeOverlap_s'}, zeros(height(S),1));
TS.PossibleApneaSupport = getLogicalColOrDefault(S, {'PossibleApneaSupport'}, false(height(S),1));
%% ------------------------------------------------------------
% STANDARDIZE SpO2 TABLE
%% ------------------------------------------------------------
TO = table();
TO.Epoch = getNumericCol(O, {'EpochNumber','Epoch'});
TO.StartTime_s = getNumericColOrDefault(O, {'EpochStart_sec','StartTime_s'}, (TO.Epoch-1)*epochLen_sec);
TO.EndTime_s   = getNumericColOrDefault(O, {'EpochEnd_sec','EndTime_s'}, TO.StartTime_s + epochLen_sec);
TO.MeanSpO2 = getNumericColOrDefault(O, {'MeanSpO2'}, nan(height(O),1));
TO.MinSpO2  = getNumericColOrDefault(O, {'MinSpO2'}, nan(height(O),1));
TO.DropMagnitude = getNumericColOrDefault(O, {'DropMagnitude'}, nan(height(O),1));
TO.DesatDuration_sec = getNumericColOrDefault(O, {'DesatDuration_sec'}, zeros(height(O),1));
TO.ValidFraction = getNumericColOrDefault(O, {'ValidFraction'}, nan(height(O),1));
TO.SpO2Label = getStringCol(O, {'Label'}, "Unknown");
% --- always create every expected logical column first ---
TO.HasDesaturation = getLogicalColOrDefault(O, {'HasDesaturation'}, false(height(O),1));
TO.HasBorderlineDrop = getLogicalColOrDefault(O, {'HasBorderlineDrop'}, false(height(O),1));
TO.HasShortDropOver3 = getLogicalColOrDefault(O, {'HasShortDropOver3','HasShortDropOver3Percent'}, false(height(O),1));
TO.HasHighVariability = getLogicalColOrDefault(O, {'HasHighVariability'}, false(height(O),1));
TO.HasLowOxygenReserve = getLogicalColOrDefault(O, {'HasLowOxygenReserve'}, false(height(O),1));
TO.HasHighInstabilityBurden = getLogicalColOrDefault(O, {'HasHighInstabilityBurden'}, false(height(O),1));
TO.HasRecoveryLikeBehavior = getLogicalColOrDefault(O, {'HasRecoveryLikeBehavior'}, false(height(O),1));
TO.HasStrongSupportiveInstability = getLogicalColOrDefault(O, {'HasStrongSupportiveInstability'}, false(height(O),1));
TO.SpO2PoorSignal = getLogicalColOrDefault(O, {'PoorSignal'}, false(height(O),1));
if ~isempty(OC)
   TO2 = table();
   TO2.Epoch = getNumericCol(OC, {'EpochNumber','Epoch'});
   % create all expected contextual columns, even if missing in file
   TO2.HasBorderlineDrop = getLogicalColOrDefault(OC, {'HasBorderlineDrop'}, false(height(OC),1));
   TO2.HasShortDropOver3 = getLogicalColOrDefault(OC, {'HasShortDropOver3','HasShortDropOver3Percent'}, false(height(OC),1));
   TO2.HasHighVariability = getLogicalColOrDefault(OC, {'HasHighVariability'}, false(height(OC),1));
   TO2.HasLowOxygenReserve = getLogicalColOrDefault(OC, {'HasLowOxygenReserve'}, false(height(OC),1));
   TO2.HasHighInstabilityBurden = getLogicalColOrDefault(OC, {'HasHighInstabilityBurden'}, false(height(OC),1));
   TO2.HasRecoveryLikeBehavior = getLogicalColOrDefault(OC, {'HasRecoveryLikeBehavior'}, false(height(OC),1));
   TO2.HasStrongSupportiveInstability = getLogicalColOrDefault(OC, {'HasStrongSupportiveInstability'}, false(height(OC),1));
   TO2.PoorSignal = getLogicalColOrDefault(OC, {'PoorSignal'}, false(height(OC),1));
   TO = outerjoin(TO, TO2, 'Keys','Epoch', 'MergeKeys',true, 'Type','left');
   % combine left/right safely
   TO.HasBorderlineDrop = mergeBoolCols(TO, 'HasBorderlineDrop_TO', 'HasBorderlineDrop_TO2', false(height(TO),1));
   TO.HasShortDropOver3 = mergeBoolCols(TO, 'HasShortDropOver3_TO', 'HasShortDropOver3_TO2', false(height(TO),1));
   TO.HasHighVariability = mergeBoolCols(TO, 'HasHighVariability_TO', 'HasHighVariability_TO2', false(height(TO),1));
   TO.HasLowOxygenReserve = mergeBoolCols(TO, 'HasLowOxygenReserve_TO', 'HasLowOxygenReserve_TO2', false(height(TO),1));
   TO.HasHighInstabilityBurden = mergeBoolCols(TO, 'HasHighInstabilityBurden_TO', 'HasHighInstabilityBurden_TO2', false(height(TO),1));
   TO.HasRecoveryLikeBehavior = mergeBoolCols(TO, 'HasRecoveryLikeBehavior_TO', 'HasRecoveryLikeBehavior_TO2', false(height(TO),1));
   TO.HasStrongSupportiveInstability = mergeBoolCols(TO, 'HasStrongSupportiveInstability_TO', 'HasStrongSupportiveInstability_TO2', false(height(TO),1));
   TO.SpO2PoorSignal = mergeBoolCols(TO, 'SpO2PoorSignal', 'PoorSignal', false(height(TO),1));
   % keep only clean columns
   varsToDrop = intersect( ...
       {'HasBorderlineDrop_TO','HasBorderlineDrop_TO2', ...
        'HasShortDropOver3_TO','HasShortDropOver3_TO2', ...
        'HasHighVariability_TO','HasHighVariability_TO2', ...
        'HasLowOxygenReserve_TO','HasLowOxygenReserve_TO2', ...
        'HasHighInstabilityBurden_TO','HasHighInstabilityBurden_TO2', ...
        'HasRecoveryLikeBehavior_TO','HasRecoveryLikeBehavior_TO2', ...
        'HasStrongSupportiveInstability_TO','HasStrongSupportiveInstability_TO2', ...
        'PoorSignal'}, ...
       TO.Properties.VariableNames);
   if ~isempty(varsToDrop)
       TO(:, varsToDrop) = [];
   end
end
% strict SpO2 validator
TO.SpO2ValidatorStrict = ...
   (~TO.SpO2PoorSignal) & ...
   ( TO.HasDesaturation | ...
     (TO.HasStrongSupportiveInstability & TO.HasShortDropOver3 & TO.HasRecoveryLikeBehavior) );
%% ------------------------------------------------------------
% STANDARDIZE HR TABLE
%% ------------------------------------------------------------
TH = table();
TH.Epoch = getNumericCol(H, {'EpochNumber'});
TH.StartTime_s = getNumericColOrDefault(H, {'EpochStart_sec'}, (TH.Epoch-1)*epochLen_sec);
TH.EndTime_s   = getNumericColOrDefault(H, {'EpochEnd_sec'}, TH.StartTime_s + epochLen_sec);
TH.MeanHR = getNumericColOrDefault(H, {'MeanHR'}, nan(height(H),1));
TH.MedianHR = getNumericColOrDefault(H, {'MedianHR'}, nan(height(H),1));
TH.MinHR = getNumericColOrDefault(H, {'MinHR'}, nan(height(H),1));
TH.MaxHR = getNumericColOrDefault(H, {'MaxHR'}, nan(height(H),1));
TH.StdHR = getNumericColOrDefault(H, {'StdHR'}, nan(height(H),1));
TH.HRStable   = getLogicalColOrDefault(H, {'HRStable'}, false(height(H),1));
TH.HRUnstable = getLogicalColOrDefault(H, {'HRUnstable'}, false(height(H),1));
TH.HRPoorSignal = getLogicalColOrDefault(H, {'PoorSignal'}, false(height(H),1));
TH.HRLabel = getStringCol(H, {'Label'}, "Unknown");
THC = table();
THC.Epoch = getNumericCol(HC, {'EpochNumber'});
THC.HasSharpRise = getLogicalColOrDefault(HC, {'HasSharpRise'}, false(height(HC),1));
THC.HasSharpDip = getLogicalColOrDefault(HC, {'HasSharpDip'}, false(height(HC),1));
THC.HasRecoveryPattern = getLogicalColOrDefault(HC, {'HasRecoveryPattern'}, false(height(HC),1));
THC.HasAutonomicLikeResponse = getLogicalColOrDefault(HC, {'HasAutonomicLikeResponse'}, false(height(HC),1));
THC.HasMildSupportiveChange = getLogicalColOrDefault(HC, {'HasMildSupportiveChange'}, false(height(HC),1));
TH = outerjoin(TH, THC, 'Keys','Epoch', 'MergeKeys',true, 'Type','left');
fillHRCols = {'HasSharpRise','HasSharpDip','HasRecoveryPattern','HasAutonomicLikeResponse','HasMildSupportiveChange'};
for i = 1:numel(fillHRCols)
   if ismember(fillHRCols{i}, TH.Properties.VariableNames)
       TH.(fillHRCols{i}) = fillmissing(logical(TH.(fillHRCols{i})), 'constant', false);
   else
       TH.(fillHRCols{i}) = false(height(TH),1);
   end
end
% STRICTER HR validator
TH.HRValidatorStrict = ...
   (~TH.HRPoorSignal) & ...
   ( TH.HRUnstable | TH.HasAutonomicLikeResponse | TH.HasRecoveryPattern );
%% ------------------------------------------------------------
% MERGE ALL BY EPOCH
%% ------------------------------------------------------------
T = outerjoin(TA, TS, 'Keys','Epoch', 'MergeKeys',true, 'Type','full');
T = outerjoin(T, TO, 'Keys','Epoch', 'MergeKeys',true, 'Type','full');
T = outerjoin(T, TH, 'Keys','Epoch', 'MergeKeys',true, 'Type','full');
T = sortrows(T, 'Epoch');
% Canonical StartTime_s
T.StartTime_s = nan(height(T),1);
startCandidates = {'StartTime_s_TA','StartTime_s_TS','StartTime_s_TO','StartTime_s_TH','StartTime_s'};
for i = 1:numel(startCandidates)
   vn = startCandidates{i};
   if ismember(vn, T.Properties.VariableNames)
       v = double(T.(vn));
       mask = isnan(T.StartTime_s) & isfinite(v);
       T.StartTime_s(mask) = v(mask);
   end
end
% Canonical EndTime_s
T.EndTime_s = nan(height(T),1);
endCandidates = {'EndTime_s_TA','EndTime_s_TS','EndTime_s_TO','EndTime_s_TH','EndTime_s'};
for i = 1:numel(endCandidates)
   vn = endCandidates{i};
   if ismember(vn, T.Properties.VariableNames)
       v = double(T.(vn));
       mask = isnan(T.EndTime_s) & isfinite(v);
       T.EndTime_s(mask) = v(mask);
   end
end
missingStart = isnan(T.StartTime_s);
T.StartTime_s(missingStart) = (T.Epoch(missingStart)-1) * epochLen_sec;
missingEnd = isnan(T.EndTime_s);
T.EndTime_s(missingEnd) = T.StartTime_s(missingEnd) + epochLen_sec;
% Fill main strings
strCols = {'AirflowClass','AirflowReason','FinalSnoreSeverity','FinalSoundBinary','SpO2Label','HRLabel'};
for i = 1:numel(strCols)
   if ~ismember(strCols{i}, T.Properties.VariableNames)
       T.(strCols{i}) = repmat("Unknown", height(T), 1);
   else
       x = string(T.(strCols{i}));
       x(ismissing(x)) = "Unknown";
       T.(strCols{i}) = x;
   end
end
% Fill booleans / numerics
boolCols = {'AirflowHasFlowReduced','AirflowHasApneaLike','AirflowHasApneaEvent', ...
           'SoundHasSnore','SoundHasApneaLike','PossibleApneaSupport', ...
           'HasDesaturation','HasBorderlineDrop','HasShortDropOver3','HasHighVariability', ...
           'HasLowOxygenReserve','HasHighInstabilityBurden','HasRecoveryLikeBehavior', ...
           'HasStrongSupportiveInstability','SpO2PoorSignal','SpO2ValidatorStrict', ...
           'HRStable','HRUnstable','HRPoorSignal','HasSharpRise','HasSharpDip', ...
           'HasRecoveryPattern','HasAutonomicLikeResponse','HasMildSupportiveChange', ...
           'HRValidatorStrict'};
for i = 1:numel(boolCols)
   if ~ismember(boolCols{i}, T.Properties.VariableNames)
       T.(boolCols{i}) = false(height(T),1);
   else
       T.(boolCols{i}) = fillmissing(logical(T.(boolCols{i})), 'constant', false);
   end
end
numColsZero = {'AirflowNumApneaEvents','AirflowApneaOverlap_s','SnoreCount','SnoreDuration_sec','SnoreBurden_pct', ...
              'SoftSnoreCount','ModerateSnoreCount','StrongSnoreCount','NoisyBreathingDuration_s', ...
              'NumApneaLikeEvents','ApneaLikeOverlap_s','DesatDuration_sec'};
for i = 1:numel(numColsZero)
   if ~ismember(numColsZero{i}, T.Properties.VariableNames)
       T.(numColsZero{i}) = zeros(height(T),1);
   else
       T.(numColsZero{i}) = fillmissing(T.(numColsZero{i}), 'constant', 0);
   end
end
%% ------------------------------------------------------------
% LAG-AWARE VALIDATION
%% ------------------------------------------------------------
n = height(T);
T.SpO2Validator_t = T.SpO2ValidatorStrict;
T.SpO2Validator_t1 = false(n,1);
if n > 1
   T.SpO2Validator_t1(1:n-1) = T.SpO2ValidatorStrict(2:n);
end
T.SpO2Validator_any = T.SpO2Validator_t | T.SpO2Validator_t1;
T.PhysioValidationStrict = T.SpO2Validator_any | T.HRValidatorStrict;
T.StrongValidationStrict = T.SpO2Validator_any & T.HRValidatorStrict;
%% ------------------------------------------------------------
% QUALITY / TRUST GATING
%% ------------------------------------------------------------
T.AirflowReliable = T.AirflowClass ~= "LowQuality" & T.AirflowClass ~= "Unknown";
T.SoundReliable   = T.FinalSnoreSeverity ~= "Unknown";
T.SpO2Reliable    = ~T.SpO2PoorSignal;
T.HRReliable      = ~T.HRPoorSignal;
T.PrimaryReliable   = T.AirflowReliable | T.SoundReliable;
T.ValidatorReliable = T.SpO2Reliable | T.HRReliable;
T.LowQualityEpoch   = ~T.PrimaryReliable & ~T.ValidatorReliable;
%% ------------------------------------------------------------
% PRIMARY CANDIDATES
%% ------------------------------------------------------------
T.CandidateApnea = ...
   T.AirflowHasApneaLike | ...
   T.SoundHasApneaLike | ...
   (T.AirflowHasFlowReduced & T.PossibleApneaSupport);
T.CandidateSnoring = T.SoundHasSnore;
%% ------------------------------------------------------------
% MAIN FINAL LABELS (ONLY 3 CLASSES)
%% ------------------------------------------------------------
FinalLabel = strings(n,1);
FusionConfidence = strings(n,1);
DetailedFusionTag = strings(n,1);
AirflowDetail = strings(n,1);
SoundDetail   = strings(n,1);
SpO2Detail    = strings(n,1);
HRDetail      = strings(n,1);
for i = 1:n
   % -------- detail strings --------
   if T.AirflowHasApneaLike(i)
       AirflowDetail(i) = "AirflowApneaLike";
   elseif T.AirflowHasFlowReduced(i)
       AirflowDetail(i) = "AirflowReduction";
   elseif T.AirflowClass(i) == "LowQuality"
       AirflowDetail(i) = "AirflowLowQuality";
   else
       AirflowDetail(i) = "AirflowNormal";
   end
   if T.SoundHasApneaLike(i)
       SoundDetail(i) = "ApneaLikeSound";
   elseif T.FinalSnoreSeverity(i) == "HeavySnoring"
       SoundDetail(i) = "HeavySnoring";
   elseif T.FinalSnoreSeverity(i) == "ModerateSnoring"
       SoundDetail(i) = "ModerateSnoring";
   elseif T.FinalSnoreSeverity(i) == "SoftSnoring"
       SoundDetail(i) = "SoftSnoring";
   elseif T.SoundHasSnore(i)
       SoundDetail(i) = "Snoring";
   else
       SoundDetail(i) = "SoundNormal";
   end
   if T.SpO2PoorSignal(i)
       SpO2Detail(i) = "SpO2PoorSignal";
   elseif T.HasDesaturation(i)
       SpO2Detail(i) = "SpO2Desaturation";
   elseif T.HasStrongSupportiveInstability(i)
       SpO2Detail(i) = "SpO2SupportiveInstability";
   elseif T.SpO2Label(i) ~= "Unknown"
       SpO2Detail(i) = T.SpO2Label(i);
   else
       SpO2Detail(i) = "SpO2Normal";
   end
   if T.HRPoorSignal(i)
       HRDetail(i) = "HRPoorSignal";
   elseif T.HasAutonomicLikeResponse(i)
       HRDetail(i) = "AutonomicLikeResponse";
   elseif T.HasRecoveryPattern(i)
       HRDetail(i) = "RecoveryPattern";
   elseif T.HRUnstable(i)
       HRDetail(i) = "HRUnstable";
   else
       HRDetail(i) = "HRStable";
   end
   % -------- final main label --------
   if T.CandidateApnea(i)
       if T.StrongValidationStrict(i)
           FinalLabel(i) = "SuspectedApnea";
           FusionConfidence(i) = "High";
       elseif T.PhysioValidationStrict(i)
           FinalLabel(i) = "SuspectedApnea";
           FusionConfidence(i) = "Moderate";
       else
           % apnea candidate but not validated -> keep detection reflected
           if T.CandidateSnoring(i)
               FinalLabel(i) = "Snoring";
               FusionConfidence(i) = "Moderate";
           else
               FinalLabel(i) = "Normal";
               FusionConfidence(i) = "Low";
           end
       end
   else
       if T.CandidateSnoring(i)
           FinalLabel(i) = "Snoring";
           if T.AirflowHasFlowReduced(i)
               FusionConfidence(i) = "Moderate";
           else
               FusionConfidence(i) = "High";
           end
       else
           FinalLabel(i) = "Normal";
           if T.LowQualityEpoch(i)
               FusionConfidence(i) = "Low";
           else
               FusionConfidence(i) = "High";
           end
       end
   end
   % -------- detailed fusion tag --------
   if FinalLabel(i) == "SuspectedApnea"
       if T.AirflowHasApneaLike(i) && T.SpO2Validator_any(i) && T.HRValidatorStrict(i)
           DetailedFusionTag(i) = "AirflowApneaLike+SpO2+HR";
       elseif T.AirflowHasApneaLike(i) && T.SpO2Validator_any(i)
           DetailedFusionTag(i) = "AirflowApneaLike+SpO2";
       elseif T.SoundHasApneaLike(i) && T.SpO2Validator_any(i)
           DetailedFusionTag(i) = "ApneaLikeSound+SpO2";
       elseif T.SoundHasApneaLike(i) && T.HRValidatorStrict(i)
           DetailedFusionTag(i) = "ApneaLikeSound+HR";
       elseif T.AirflowHasFlowReduced(i) && T.PossibleApneaSupport(i) && T.PhysioValidationStrict(i)
           DetailedFusionTag(i) = "FlowReduction+ApneaSupport+Physio";
       else
           DetailedFusionTag(i) = "ValidatedApneaCandidate";
       end
   elseif FinalLabel(i) == "Snoring"
       if T.FinalSnoreSeverity(i) == "HeavySnoring" && T.AirflowHasFlowReduced(i)
           DetailedFusionTag(i) = "HeavySnoring+FlowReduction";
       elseif T.FinalSnoreSeverity(i) == "ModerateSnoring" && T.AirflowHasFlowReduced(i)
           DetailedFusionTag(i) = "ModerateSnoring+FlowReduction";
       elseif T.FinalSnoreSeverity(i) == "SoftSnoring" && T.AirflowHasFlowReduced(i)
           DetailedFusionTag(i) = "SoftSnoring+FlowReduction";
       elseif T.FinalSnoreSeverity(i) == "HeavySnoring"
           DetailedFusionTag(i) = "HeavySnoring";
       elseif T.FinalSnoreSeverity(i) == "ModerateSnoring"
           DetailedFusionTag(i) = "ModerateSnoring";
       elseif T.FinalSnoreSeverity(i) == "SoftSnoring"
           DetailedFusionTag(i) = "SoftSnoring";
       else
           DetailedFusionTag(i) = "Snoring";
       end
   else
       if T.LowQualityEpoch(i)
           DetailedFusionTag(i) = "NormalButLowQuality";
       elseif T.AirflowHasFlowReduced(i) && ~T.CandidateSnoring(i)
           DetailedFusionTag(i) = "FlowReductionWithoutValidation";
       else
           DetailedFusionTag(i) = "Normal";
       end
   end
end
T.FinalLabel = FinalLabel;
T.FusionConfidence = FusionConfidence;
T.AirflowDetail = AirflowDetail;
T.SoundDetail = SoundDetail;
T.SpO2Detail = SpO2Detail;
T.HRDetail = HRDetail;
