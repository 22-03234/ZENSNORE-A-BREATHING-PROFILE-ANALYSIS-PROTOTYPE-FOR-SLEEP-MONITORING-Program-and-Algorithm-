function x = getNumericCol(T, names)
x = [];
for k = 1:numel(names)
   if ismember(names{k}, T.Properties.VariableNames)
       x = double(T.(names{k}));
       return;
   end
end
error('Missing required numeric column. Tried: %s', strjoin(names, ', '));
end
function x = getNumericColOrDefault(T, names, defaultVal)
for k = 1:numel(names)
   if ismember(names{k}, T.Properties.VariableNames)
       x = double(T.(names{k}));
       return;
   end
end
x = defaultVal;
end
function x = getLogicalColOrDefault(T, names, defaultVal)
for k = 1:numel(names)
   if ismember(names{k}, T.Properties.VariableNames)
       x = logical(T.(names{k}));
       return;
   end
end
x = defaultVal;
end
function x = getStringCol(T, names, defaultVal)
for k = 1:numel(names)
   if ismember(names{k}, T.Properties.VariableNames)
       x = string(T.(names{k}));
       x(ismissing(x)) = defaultVal;
       return;
   end
end
x = repmat(string(defaultVal), height(T), 1);
end
function x = getColIfExists(T, name, defaultVal)
if ismember(name, T.Properties.VariableNames)
   x = T.(name);
else
   x = defaultVal;
end
end
function x = mergeBoolCols(T, leftName, rightName, fallback)
if nargin < 4
   fallback = false(height(T),1);
end
x = fallback;
if ismember(leftName, T.Properties.VariableNames)
   x = x | fillmissing(logical(T.(leftName)), 'constant', false);
end
if ismember(rightName, T.Properties.VariableNames)
   x = x | fillmissing(logical(T.(rightName)), 'constant', false);
end
end
function plotEpochShading(ax, T, zoomStart_s, zoomEnd_s)
axes(ax);
hold(ax, 'on');
idx = (T.StartTime_s < zoomEnd_s) & (T.EndTime_s > zoomStart_s);
Te = T(idx,:);
if isempty(Te)
   return;
end
yl = ylim(ax);
for i = 1:height(Te)
   xs = [Te.StartTime_s(i) Te.EndTime_s(i) Te.EndTime_s(i) Te.StartTime_s(i)];
   ys = [yl(1) yl(1) yl(2) yl(2)];
   if Te.FinalLabel(i) == "SuspectedApnea"
       faceAlpha = 0.12;
   elseif Te.FinalLabel(i) == "Snoring"
       faceAlpha = 0.08;
   else
       faceAlpha = 0.03;
   end
   patch(ax, xs, ys, [0.5 0.5 0.5], ...
       'FaceAlpha', faceAlpha, ...
       'EdgeColor', 'none', ...
       'HandleVisibility', 'off');
   ytxt = yl(2) - 0.08*(yl(2)-yl(1));
   text(ax, Te.StartTime_s(i)+1, ytxt, ...
       sprintf('E%d %s', Te.Epoch(i), Te.FinalLabel(i)), ...
       'FontSize', 7, ...
       'Clipping', 'on');
end
end
function plotAirflowPanel(airflowTrace, T, zoomStart_s, zoomEnd_s)
ax = gca;
hold on;
if ~isempty(airflowTrace)
   t = getNumericCol(airflowTrace, {'Time_s'});
   idx = (t >= zoomStart_s) & (t <= zoomEnd_s);
   if any(idx)
       if ismember('AirflowRaw', airflowTrace.Properties.VariableNames)
           plot(t(idx), airflowTrace.AirflowRaw(idx), 'DisplayName','Raw');
       end
       if ismember('AirflowFiltered', airflowTrace.Properties.VariableNames)
           plot(t(idx), airflowTrace.AirflowFiltered(idx), 'LineWidth',1.2, 'DisplayName','Filtered');
       end
       if ismember('Envelope', airflowTrace.Properties.VariableNames)
           plot(t(idx), airflowTrace.Envelope(idx), 'LineWidth',1.1, 'DisplayName','Envelope');
       end
       if ismember('LocalBaseline', airflowTrace.Properties.VariableNames)
           plot(t(idx), airflowTrace.LocalBaseline(idx)*0.10, '--', 'LineWidth',1.0, 'DisplayName','10% Baseline');
       end
   end
else
   text(mean([zoomStart_s zoomEnd_s]), 0, 'Airflow trace not found', 'HorizontalAlignment','center');
end
xlim([zoomStart_s zoomEnd_s]);
plotEpochShading(ax, T, zoomStart_s, zoomEnd_s);
legend('show','Location','best');
end
function plotSoundPanel(soundWins, rawAudioFile, rawAudio1File, rawAudio2File, T, zoomStart_s, zoomEnd_s)
ax = gca;
hold on;
audioLoaded = false;
try
   if isfile(rawAudioFile)
       info = audioinfo(rawAudioFile);
       fs = info.SampleRate;
       s1 = max(1, floor(zoomStart_s*fs)+1);
       s2 = min(info.TotalSamples, ceil(zoomEnd_s*fs));
       [y, fs] = audioread(rawAudioFile, [s1 s2]);
       if size(y,2) > 1, y = mean(y,2); end
       t = ((0:numel(y)-1)'/fs) + zoomStart_s;
       plot(t, y, 'DisplayName','Audio Raw');
       [b,a] = butter(4, [20 300]/(fs/2), 'bandpass');
       yf = filtfilt(b,a,y);
       env = movmean(abs(yf), max(5, round(0.03*fs)));
       plot(t, yf, 'LineWidth',1.0, 'DisplayName','Audio Filtered');
       plot(t, env, 'LineWidth',1.4, 'DisplayName','Envelope');
       audioLoaded = true;
   elseif isfile(rawAudio1File) && isfile(rawAudio2File)
       % Fallback: plot window features only if merged audio not available
       audioLoaded = false;
   end
catch
   audioLoaded = false;
end
if ~audioLoaded
   if ~isempty(soundWins)
       t1 = getNumericCol(soundWins, {'start_time_s'});
       t2 = getNumericCol(soundWins, {'end_time_s'});
       mid = (t1 + t2)/2;
       idx = (mid >= zoomStart_s) & (mid <= zoomEnd_s);
       if any(idx)
           if ismember('rms', soundWins.Properties.VariableNames)
               plot(mid(idx), soundWins.rms(idx), '-o', 'DisplayName','RMS');
           end
           if ismember('rms_norm', soundWins.Properties.VariableNames)
               plot(mid(idx), soundWins.rms_norm(idx), '-s', 'LineWidth',1.1, 'DisplayName','RMS norm');
           end
           if ismember('peak_freq_hz', soundWins.Properties.VariableNames)
               yyaxis right
               plot(mid(idx), soundWins.peak_freq_hz(idx), 'DisplayName','Peak Freq');
               ylabel('Hz');
               yyaxis left
           end
       else
           text(mean([zoomStart_s zoomEnd_s]), 0, 'No sound windows in zoom range', 'HorizontalAlignment','center');
       end
   else
       text(mean([zoomStart_s zoomEnd_s]), 0, 'Sound trace not found', 'HorizontalAlignment','center');
   end
end
xlim([zoomStart_s zoomEnd_s]);
plotEpochShading(ax, T, zoomStart_s, zoomEnd_s);
legend('show','Location','best');
end
