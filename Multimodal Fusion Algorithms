%% ------------------------------------------------------------
% MOST RELEVANT 3-MIN WINDOW SELECTION
%% ------------------------------------------------------------
score = zeros(n,1);
score = score + 8*(T.FinalLabel == "SuspectedApnea");
score = score + 4*(T.CandidateApnea);
score = score + 3*(T.SoundHasApneaLike);
score = score + 2*(T.AirflowHasApneaLike);
score = score + 2*(T.AirflowHasFlowReduced);
