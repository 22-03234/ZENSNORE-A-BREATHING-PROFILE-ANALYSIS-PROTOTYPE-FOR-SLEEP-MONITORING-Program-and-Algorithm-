       end
       if ismember('RED_filtered', hrProc.Properties.VariableNames)
           plot(t(idx), hrProc.RED_filtered(idx), 'LineWidth',1.2, 'DisplayName','RED filtered');
           plotted = true;
       end
   end
end
if ~isempty(hrTrace)
   t2 = getNumericCol(hrTrace, {'time_s'});
   idx2 = (t2 >= zoomStart_s) & (t2 <= zoomEnd_s);
   if any(idx2)
       yyaxis right
       if ismember('hr_bpm', hrTrace.Properties.VariableNames)
           plot(t2(idx2), hrTrace.hr_bpm(idx2), '-o', 'DisplayName','HR bpm');
       end
       if ismember('hr_smooth_bpm', hrTrace.Properties.VariableNames)
           plot(t2(idx2), hrTrace.hr_smooth_bpm(idx2), 'LineWidth',1.4, 'DisplayName','HR smooth');
       end
       ylabel('HR (bpm)');
       yyaxis left
       plotted = true;
   end
end
if ~plotted
   text(mean([zoomStart_s zoomEnd_s]), 0, 'HR trace not found', 'HorizontalAlignment','center');
end
xlim([zoomStart_s zoomEnd_s]);
plotEpochShading(ax, T, zoomStart_s, zoomEnd_s);
legend('show','Location','best');
end

