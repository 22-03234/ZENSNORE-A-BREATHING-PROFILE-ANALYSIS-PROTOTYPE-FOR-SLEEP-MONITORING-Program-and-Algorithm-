AUDIO_USE_HANN = True
AUDIO_RMS_MIN = 0.00015




# =========================
# ADS1115 helpers
# =========================
REG_CONVERSION = 0x00
REG_CONFIG     = 0x01


DR_MAP = {
    8:0b000,16:0b001,32:0b010,64:0b011,
    128:0b100,250:0b101,475:0b110,860:0b111
}


def ads_mux_bits(ch: int) -> int:
    return {0:0b100,1:0b101,2:0b110,3:0b111}[ch]


def ads_write_config(bus: SMBus) -> None:
    config = (
        (1<<15) |
        (ads_mux_bits(ADS_CHANNEL)<<12) |
        (PGA_BITS<<9) |
        (1<<8) |
        (DR_MAP[ADS_ADC_RATE]<<5) |
        (0b11)
    )
    bus.write_i2c_block_data(
        ADS_ADDR, REG_CONFIG,
        [(config>>8) & 0xFF, config & 0xFF]
    )


def ads_read_raw(bus: SMBus) -> int:
    data = bus.read_i2c_block_data(ADS_ADDR, REG_CONVERSION, 2)
    raw = (data[0]<<8) | data[1]
    if raw & 0x8000:
        raw -= 1<<16
    return raw


def raw_to_voltage(raw: int) -> float:
    return (raw / 32768.0) * ADS_FS_V


def voltage_to_kpa(v: float) -> float:
    return (v / MPX_VS_SUPPLY - 0.5) / 0.2




# =========================
# Audio helpers
# =========================
def parabolic_peak(freqs_band: np.ndarray, mag_band: np.ndarray, k: int) -> float:
    if k <= 0 or k >= len(mag_band) - 1:
        return float(freqs_band[k])
    a = mag_band[k-1]
    b = mag_band[k]
    c = mag_band[k+1]
    denom = (a - 2*b + c)
    if denom == 0:
        return float(freqs_band[k])
    delta = 0.5 * (a - c) / denom
    df = freqs_band[1] - freqs_band[0]
    return float(freqs_band[k] + delta * df)




