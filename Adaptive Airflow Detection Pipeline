end


fprintf('\nOutput files created:\n');
fprintf('  1) airflow_epoch_features.csv\n');
fprintf('  2) airflow_epoch_classification.csv\n');
fprintf('  3) airflow_apnea_events.csv\n');
fprintf('  4) airflow_epoch_apnea_map.csv\n');
fprintf('  5) airflow_epoch_final_classification.csv\n');


