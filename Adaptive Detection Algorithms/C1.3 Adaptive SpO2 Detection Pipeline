clc;
clear;
close all;
%% =========================================================
%% ZENSNORE MASTER SpO2 PIPELINE (ROBUST / ADAPTIVE 2-LAYER)
%% Reusable for ZenSnore PPG datasets with columns:
%% t_ns, RED, IR
%%
%% LAYER 1 = validated desaturation detection
%% LAYER 2 = supportive/contextual oxygen behavior
%% Added robustness:
%% - adaptive PPG quality screening
%% - pulsatility-based R validity
%% - epoch-level PoorSignal flag
%% - adaptive variability threshold
%% - stronger artifact/dropout handling
%% =========================================================
%% ==============================
%% USER SETTINGS / PARAMETERS
%% ==============================
input_file = 'ppg.csv';
% Output file names
output_recomputed_file        = 'spo2_recomputed_from_raw.csv';
output_final_file             = 'spo2_final_artifact_rejected.csv';
output_events_file            = 'spo2_desaturation_events.csv';
output_epoch_file             = 'spo2_epoch_classification.csv';
output_context_epoch_file     = 'spo2_contextual_epoch_flags.csv';
% PPG processing
bp_low = 0.5;                  % Hz
bp_high = 2.5;                 % Hz
bp_order = 3;
dc_window_sec = 2;             % moving average window for DC extraction
r_window_sec = 4;              % window for AC RMS and R computation
r_step_sec = 1;                % update every 1 second
% R filtering
r_min = 0.3;
r_max = 1.0;
r_smooth_window = 3;
% SpO2 estimation
spo2_formula_a = 110;
spo2_formula_b = 25;           % SpO2 = a - b*R
% SpO2 physiologic filtering
spo2_min_phys = 85;
spo2_max_phys = 100;
spo2_smooth_window = 3;
% Artifact rejection
max_spo2_change_per_sec = 4;   % %/sec
interpolate_artifacts = true;
max_gap_interp_sec = 10;       % only fill short gaps
% Baseline / desaturation
baseline_window_sec = 120;     % 2-minute moving baseline
drop_threshold = 3;            % desaturation threshold (% from baseline)
min_event_duration_sec = 10;   % minimum sustained duration
% Epoching
epoch_len_sec = 30;
% Contextual / Layer 2 thresholds
borderline_drop_low = 2;       % borderline lower bound
instability_burden_threshold = 8;
recovery_rise_threshold = 1.0;
% Final refined low oxygen reserve thresholds
low_oxygen_reserve_mean_thr = 92.5;
low_oxygen_reserve_min_thr  = 92.0;
% New quality controls
min_dc_level = 1;                  % avoids divide-by-near-zero
min_valid_fraction_epoch = 0.50;   % <50% good samples in epoch => PoorSignal
dropout_run_sec = 5;               % long dropout run threshold
weak_pulsatility_quantile = 15;    % adaptive weak pulsatility threshold
high_variability_quantile = 80;    % adaptive epoch variability threshold
%% ==============================
%% LOAD DATA
%% ==============================
data = readtable(input_file);
required_vars = {'t_ns','RED','IR'};
for i = 1:length(required_vars)
   if ~ismember(required_vars{i}, data.Properties.VariableNames)
       error('Missing required column: %s', required_vars{i});
   end
end
t_ns = data.t_ns;
RED = double(data.RED);
IR  = double(data.IR);
valid_raw = isfinite(t_ns) & isfinite(RED) & isfinite(IR);
t_ns = t_ns(valid_raw);
RED = RED(valid_raw);
IR = IR(valid_raw);
if isempty(t_ns)
   error('No valid PPG samples found after raw filtering.');
end
t_sec = (t_ns - t_ns(1)) / 1e9;
t_min = t_sec / 60;
%% ==============================
%% ESTIMATE SAMPLING RATE
%% ==============================
dt = median(diff(t_sec), 'omitnan');
fs = 1 / dt;
fprintf('Estimated fs: %.2f Hz\n', fs);
%% ==============================
%% FILTER SETTINGS IN SAMPLES
%% ==============================
dc_window_samples = max(1, round(dc_window_sec * fs));
r_window_samples  = max(1, round(r_window_sec * fs));
r_step_samples    = max(1, round(r_step_sec * fs));
%% ==============================
%% AC EXTRACTION (BANDPASS)
%% ==============================
[b_bp, a_bp] = butter(bp_order, [bp_low bp_high] / (fs/2), 'bandpass');
RED_ac = filtfilt(b_bp, a_bp, RED);
IR_ac  = filtfilt(b_bp, a_bp, IR);
%% ==============================
%% DC EXTRACTION (MOVING AVERAGE)
%% ==============================
RED_dc = movmean(RED, dc_window_samples);
IR_dc  = movmean(IR, dc_window_samples);
%% ==============================
%% COMPUTE WINDOWED R + QUALITY
%% ==============================
start_indices = 1:r_step_samples:(length(t_sec) - r_window_samples + 1);
num_windows = length(start_indices);
t_R_sec = zeros(num_windows,1);
t_R_min = zeros(num_windows,1);
RED_AC_RMS = zeros(num_windows,1);
IR_AC_RMS  = zeros(num_windows,1);
RED_DC_MEAN = zeros(num_windows,1);
IR_DC_MEAN  = zeros(num_windows,1);
RED_PI = zeros(num_windows,1);   % AC/DC proxy
IR_PI  = zeros(num_windows,1);   % AC/DC proxy
R_new = nan(num_windows,1);
for k = 1:num_windows
   idx1 = start_indices(k);
   idx2 = idx1 + r_window_samples - 1;
   idx = idx1:idx2;
   RED_AC_RMS(k) = sqrt(mean(RED_ac(idx).^2, 'omitnan'));
   IR_AC_RMS(k)  = sqrt(mean(IR_ac(idx).^2, 'omitnan'));
   RED_DC_MEAN(k) = mean(RED_dc(idx), 'omitnan');
   IR_DC_MEAN(k)  = mean(IR_dc(idx), 'omitnan');
   if RED_DC_MEAN(k) > 0
       RED_PI(k) = RED_AC_RMS(k) / RED_DC_MEAN(k);
   else
       RED_PI(k) = NaN;
   end
   if IR_DC_MEAN(k) > 0
       IR_PI(k) = IR_AC_RMS(k) / IR_DC_MEAN(k);
   else
       IR_PI(k) = NaN;
   end
   if IR_AC_RMS(k) > 0 && RED_DC_MEAN(k) > min_dc_level && IR_DC_MEAN(k) > min_dc_level
       R_new(k) = (RED_AC_RMS(k) * IR_DC_MEAN(k)) / (IR_AC_RMS(k) * RED_DC_MEAN(k));
   else
       R_new(k) = NaN;
   end
   center_idx = round((idx1 + idx2)/2);
   t_R_sec(k) = t_sec(center_idx);
   t_R_min(k) = t_min(center_idx);
end
%% ==============================
%% REMOVE INVALID R
%% ==============================
valid_R = ~isnan(R_new) & isfinite(R_new) & R_new > 0;
t_R_sec = t_R_sec(valid_R);
t_R_min = t_R_min(valid_R);
RED_AC_RMS = RED_AC_RMS(valid_R);
IR_AC_RMS = IR_AC_RMS(valid_R);
RED_DC_MEAN = RED_DC_MEAN(valid_R);
IR_DC_MEAN = IR_DC_MEAN(valid_R);
RED_PI = RED_PI(valid_R);
IR_PI = IR_PI(valid_R);
R_new = R_new(valid_R);
if isempty(R_new)
   error('No valid R values found after initial R screening.');
end
%% ==============================
%% ADAPTIVE PULSATILITY QUALITY SCREENING
%% ==============================
validPI = [RED_PI(isfinite(RED_PI)); IR_PI(isfinite(IR_PI))];
if isempty(validPI)
   error('No valid pulsatility values found.');
end
pi_low_thr = prctile(validPI, weak_pulsatility_quantile);
good_pulsatility = ...
   isfinite(RED_PI) & isfinite(IR_PI) & ...
   RED_PI >= pi_low_thr & IR_PI >= pi_low_thr;
good_dc = RED_DC_MEAN > min_dc_level & IR_DC_MEAN > min_dc_level;
R_phys = R_new >= r_min & R_new <= r_max;
window_quality_mask = good_pulsatility & good_dc & R_phys;
t_R_clean_sec = t_R_sec(window_quality_mask);
t_R_clean_min = t_R_min(window_quality_mask);
RED_AC_RMS = RED_AC_RMS(window_quality_mask);
IR_AC_RMS = IR_AC_RMS(window_quality_mask);
RED_DC_MEAN = RED_DC_MEAN(window_quality_mask);
IR_DC_MEAN = IR_DC_MEAN(window_quality_mask);
RED_PI = RED_PI(window_quality_mask);
IR_PI = IR_PI(window_quality_mask);
R_clean = R_new(window_quality_mask);
if isempty(R_clean)
   error('No valid R values remained after physiologic and pulsatility filtering.');
end
R_smooth = movmean(R_clean, r_smooth_window, 'omitnan');
%% ==============================
%% COMPUTE ESTIMATED SpO2
%% ==============================
SpO2_est = spo2_formula_a - spo2_formula_b * R_smooth;
%% ==============================
%% PHYSIOLOGIC SpO2 FILTERING
%% ==============================
spo2_phys = SpO2_est >= spo2_min_phys & SpO2_est <= spo2_max_phys;
t_final_sec = t_R_clean_sec(spo2_phys);
t_final_min = t_R_clean_min(spo2_phys);
R_final = R_clean(spo2_phys);
R_smooth_final = R_smooth(spo2_phys);
RED_AC_RMS_final = RED_AC_RMS(spo2_phys);
IR_AC_RMS_final = IR_AC_RMS(spo2_phys);
RED_DC_final = RED_DC_MEAN(spo2_phys);
IR_DC_final = IR_DC_MEAN(spo2_phys);
RED_PI_final = RED_PI(spo2_phys);
IR_PI_final = IR_PI(spo2_phys);
SpO2_final = SpO2_est(spo2_phys);
if isempty(SpO2_final)
   error('No valid SpO2 values remained after physiologic filtering.');
end
SpO2_final_smooth = movmean(SpO2_final, spo2_smooth_window, 'omitnan');
%% ==============================
%% ARTIFACT REJECTION
%% ==============================
SpO2_before_artifact = SpO2_final_smooth;
t_art = t_final_sec;
dSpO2 = [0; diff(SpO2_before_artifact)];
artifact_idx = abs(dSpO2) > max_spo2_change_per_sec;
artifact_idx = artifact_idx | ~isfinite(SpO2_before_artifact);
SpO2_artifact_removed = SpO2_before_artifact;
SpO2_artifact_removed(artifact_idx) = NaN;
if interpolate_artifacts
   nan_mask = isnan(SpO2_artifact_removed);
   dnan = diff([0; nan_mask; 0]);
   nan_starts = find(dnan == 1);
   nan_ends = find(dnan == -1) - 1;
   nan_lengths = nan_ends - nan_starts + 1;
   fill_mask = false(size(nan_mask));
   for i = 1:numel(nan_starts)
       if nan_lengths(i) <= max_gap_interp_sec
           fill_mask(nan_starts(i):nan_ends(i)) = true;
       end
   end
   tmp = SpO2_artifact_removed;
   tmp(~fill_mask & isnan(tmp)) = -9999;
   tmp(tmp == -9999) = NaN;
   SpO2_clean = fillmissing(tmp, 'linear');
else
   SpO2_clean = SpO2_artifact_removed;
end
%% ==============================
%% SAVE FINAL CONTINUOUS OUTPUT
%% ==============================
FinalTable = table( ...
   t_art, t_art/60, ...
   R_final, R_smooth_final, ...
   RED_AC_RMS_final, IR_AC_RMS_final, ...
   RED_DC_final, IR_DC_final, ...
   RED_PI_final, IR_PI_final, ...
   SpO2_final, SpO2_before_artifact, SpO2_clean, ...
   'VariableNames', {'Time_sec','Time_min','R_raw','R_smooth', ...
   'RED_AC_RMS','IR_AC_RMS','RED_DC','IR_DC','RED_PI','IR_PI', ...
   'SpO2_raw','SpO2_before_artifact_rejection','SpO2_clean'});
writetable(FinalTable, output_final_file);
%% ==============================
%% RESAMPLE TO 1 HZ
%% ==============================
valid_clean = ~isnan(t_art) & ~isnan(SpO2_clean) & isfinite(t_art) & isfinite(SpO2_clean);
t_art = t_art(valid_clean);
SpO2_clean = SpO2_clean(valid_clean);
if numel(t_art) < 2
   error('Not enough valid SpO2 samples after artifact rejection for 1 Hz resampling.');
end
t_uniform = (ceil(t_art(1)):floor(t_art(end)))';
SpO2_uniform = interp1(t_art, SpO2_clean, t_uniform, 'linear');
t_uniform_min = t_uniform / 60;
valid_uniform = isfinite(SpO2_uniform);
t_uniform = t_uniform(valid_uniform);
t_uniform_min = t_uniform_min(valid_uniform);
SpO2_uniform = SpO2_uniform(valid_uniform);
%% ==============================
%% BASELINE + LAYER 1 DESATURATION DETECTION
%% ==============================
baseline = movmedian(SpO2_uniform, baseline_window_sec, 'omitnan');
drop_from_baseline = baseline - SpO2_uniform;
desat_flag = drop_from_baseline >= drop_threshold;
d = diff([0; desat_flag; 0]);
start_idx = find(d == 1);
end_idx   = find(d == -1) - 1;
durations = end_idx - start_idx + 1;
keep = durations >= min_event_duration_sec;
start_idx = start_idx(keep);
end_idx = end_idx(keep);
durations = durations(keep);
num_events = length(start_idx);
event_start_sec = t_uniform(start_idx);
event_end_sec = t_uniform(end_idx);
event_start_min = event_start_sec / 60;
event_end_min = event_end_sec / 60;
event_duration_sec = durations;
event_drop_max = zeros(num_events,1);
event_spo2_min = zeros(num_events,1);
event_baseline_mean = zeros(num_events,1);
desat_event_mask = false(size(SpO2_uniform));
for i = 1:num_events
   idx = start_idx(i):end_idx(i);
   desat_event_mask(idx) = true;
   event_drop_max(i) = max(drop_from_baseline(idx), [], 'omitnan');
   event_spo2_min(i) = min(SpO2_uniform(idx), [], 'omitnan');
   event_baseline_mean(i) = mean(baseline(idx), 'omitnan');
end
DesatEvents = table( ...
   event_start_sec, event_end_sec, ...
   event_start_min, event_end_min, ...
   event_duration_sec, event_drop_max, ...
   event_spo2_min, event_baseline_mean, ...
   'VariableNames', {'event_start_sec','event_end_sec', ...
   'event_start_min','event_end_min','event_duration_sec', ...
   'event_drop_max','event_spo2_min','event_baseline_mean'});
writetable(DesatEvents, output_events_file);
%% ==============================
%% 30-SECOND EPOCH FEATURE EXTRACTION
%% LAYER 1 + LAYER 2 + SIGNAL QUALITY
%% ==============================
N = length(SpO2_uniform);
num_epochs = floor(N / epoch_len_sec);
EpochNumber             = zeros(num_epochs,1);
EpochStart_sec          = zeros(num_epochs,1);
EpochEnd_sec            = zeros(num_epochs,1);
MeanSpO2                = zeros(num_epochs,1);
MinSpO2                 = zeros(num_epochs,1);
BaselineMean            = zeros(num_epochs,1);
DropMagnitude           = zeros(num_epochs,1);
DesatDuration_sec       = zeros(num_epochs,1);
RateOfDecline           = zeros(num_epochs,1);
SpO2Std                 = zeros(num_epochs,1);
TimeBelow90_sec         = zeros(num_epochs,1);
HasDesaturation         = false(num_epochs,1);
HasShortDropOver3       = false(num_epochs,1);
HasBorderlineDrop       = false(num_epochs,1);
Label                   = strings(num_epochs,1);
HasLowOxygenReserve      = false(num_epochs,1);
HasRecoveryPattern       = false(num_epochs,1);
InstabilityBurden_sec    = zeros(num_epochs,1);
HasHighInstabilityBurden = false(num_epochs,1);
ContextLabel             = strings(num_epochs,1);
Layer2SupportScore       = zeros(num_epochs,1);
ValidFraction            = zeros(num_epochs,1);
HasLongDropout           = false(num_epochs,1);
PoorSignal               = false(num_epochs,1);
% Adaptive variability threshold from this recording
tmp_std = zeros(num_epochs,1);
for e = 1:num_epochs
   idx1 = (e-1)*epoch_len_sec + 1;
   idx2 = e*epoch_len_sec;
   x = SpO2_uniform(idx1:idx2);
   tmp_std(e) = std(x, 'omitnan');
end
variability_threshold = prctile(tmp_std(isfinite(tmp_std)), high_variability_quantile);
for e = 1:num_epochs
   idx1 = (e-1)*epoch_len_sec + 1;
   idx2 = e*epoch_len_sec;
   idx = idx1:idx2;
   x = SpO2_uniform(idx);
   b = baseline(idx);
   dr = drop_from_baseline(idx);
   dm = desat_event_mask(idx);
   EpochNumber(e)       = e;
   EpochStart_sec(e)    = t_uniform(idx1);
   EpochEnd_sec(e)      = t_uniform(idx2);
   MeanSpO2(e)          = mean(x, 'omitnan');
   MinSpO2(e)           = min(x, [], 'omitnan');
   BaselineMean(e)      = mean(b, 'omitnan');
   DropMagnitude(e)     = max(dr, [], 'omitnan');
   DesatDuration_sec(e) = sum(dm);
   SpO2Std(e)           = std(x, 'omitnan');
   TimeBelow90_sec(e)   = sum(x < 90);
   dx = diff(x);
   negative_dx = dx(dx < 0);
   if isempty(negative_dx)
       RateOfDecline(e) = 0;
   else
       RateOfDecline(e) = abs(min(negative_dx));
   end
   % Quality estimate within epoch
   ValidFraction(e) = sum(isfinite(x)) / numel(x);
   badmask = ~isfinite(x);
   d_bad = diff([0; badmask(:); 0]);
   bad_starts = find(d_bad == 1);
   bad_ends = find(d_bad == -1) - 1;
   bad_lengths = bad_ends - bad_starts + 1;
   HasLongDropout(e) = any(bad_lengths >= dropout_run_sec);
   PoorSignal(e) = ValidFraction(e) < min_valid_fraction_epoch || HasLongDropout(e);
   % ---------- Layer 1 ----------
   HasDesaturation(e)   = any(dm);
   HasBorderlineDrop(e) = any(dr >= borderline_drop_low & dr < drop_threshold);
   HasShortDropOver3(e) = any(dr >= drop_threshold) && ~any(dm);
   if PoorSignal(e)
       Label(e) = "PoorSignal";
   elseif HasDesaturation(e)
       Label(e) = "Desaturation Event";
   elseif HasShortDropOver3(e) || HasBorderlineDrop(e) || SpO2Std(e) > variability_threshold
       Label(e) = "Uncertain";
   else
       Label(e) = "Normal Oxygenation";
   end
   % ---------- Layer 2 ----------
   HasLowOxygenReserve(e) = ...
       (MeanSpO2(e) < low_oxygen_reserve_mean_thr) || ...
       (MinSpO2(e) < low_oxygen_reserve_min_thr);
   InstabilityBurden_sec(e) = sum(dr >= borderline_drop_low);
   HasHighInstabilityBurden(e) = InstabilityBurden_sec(e) >= instability_burden_threshold;
   if numel(x) >= 3
       local_min = min(x, [], 'omitnan');
       local_end_mean = mean(x(max(1,end-4):end), 'omitnan');
       HasRecoveryPattern(e) = (local_end_mean - local_min) >= recovery_rise_threshold;
   else
       HasRecoveryPattern(e) = false;
   end
   Layer2SupportScore(e) = ...
       double(HasBorderlineDrop(e)) + ...
       double(HasShortDropOver3(e)) + ...
       double(SpO2Std(e) > variability_threshold) + ...
       double(HasLowOxygenReserve(e)) + ...
       double(HasHighInstabilityBurden(e)) + ...
       double(HasRecoveryPattern(e));
   if PoorSignal(e)
       ContextLabel(e) = "Low-confidence oxygen epoch";
   elseif HasDesaturation(e)
       ContextLabel(e) = "Confirmed oxygen consequence";
   elseif Layer2SupportScore(e) >= 3
       ContextLabel(e) = "Strong supportive oxygen instability";
   elseif Layer2SupportScore(e) >= 1
       ContextLabel(e) = "Mild supportive oxygen change";
   else
       ContextLabel(e) = "Stable oxygen behavior";
   end
end
%% ==============================
%% SAVE LAYER 1 EPOCH OUTPUT
%% ==============================
EpochTable = table( ...
   EpochNumber, EpochStart_sec, EpochEnd_sec, ...
   MeanSpO2, MinSpO2, BaselineMean, DropMagnitude, ...
   DesatDuration_sec, RateOfDecline, SpO2Std, TimeBelow90_sec, ...
   ValidFraction, HasLongDropout, PoorSignal, ...
   HasDesaturation, HasShortDropOver3, HasBorderlineDrop, Label);
writetable(EpochTable, output_epoch_file);
%% ==============================
%% SAVE LAYER 2 CONTEXTUAL EPOCH OUTPUT
%% ==============================
ContextEpochTable = table( ...
   EpochNumber, EpochStart_sec, EpochEnd_sec, ...
   MeanSpO2, MinSpO2, BaselineMean, DropMagnitude, SpO2Std, ...
   ValidFraction, HasLongDropout, PoorSignal, ...
   HasBorderlineDrop, HasShortDropOver3, ...
   HasLowOxygenReserve, InstabilityBurden_sec, HasHighInstabilityBurden, ...
   HasRecoveryPattern, Layer2SupportScore, ContextLabel);
writetable(ContextEpochTable, output_context_epoch_file);
%% ==============================
%% SAVE RECOMPUTED RAW-TO-SPO2 STAGE
%% ==============================
RecomputedTable = table( ...
   t_final_sec, ...
   t_final_min, ...
   R_final, ...
   R_smooth_final, ...
   RED_AC_RMS_final, ...
   IR_AC_RMS_final, ...
   RED_DC_final, ...
   IR_DC_final, ...
   RED_PI_final, ...
   IR_PI_final, ...
   SpO2_final, ...
   SpO2_before_artifact, ...
   'VariableNames', { ...
   'Time_sec','Time_min','R_raw','R_smooth', ...
   'RED_AC_RMS','IR_AC_RMS','RED_DC','IR_DC', ...
   'RED_PI','IR_PI','SpO2_raw','SpO2_before_artifact_rejection'});
writetable(RecomputedTable, output_recomputed_file);
%% ==============================
%% COMMAND WINDOW SUMMARY
%% ==============================
disp(' ');
disp('============================================================');
disp('     ZENSNORE MASTER SpO2 PIPELINE (ROBUST / ADAPTIVE)');
disp('============================================================');
fprintf('Input file                              : %s\n', input_file);
fprintf('Estimated sampling rate                 : %.2f Hz\n', fs);
fprintf('Recording duration                      : %.2f min\n', t_min(end));
disp(' ');
disp('[STAGE 1] RAW PPG / R / SpO2');
fprintf('Total raw samples                       : %d\n', length(t_sec));
fprintf('Windowed R values                       : %d\n', num_windows);
fprintf('Adaptive pulsatility threshold          : %.6f\n', pi_low_thr);
fprintf('Remaining after quality + R filtering   : %d\n', length(R_clean));
fprintf('Remaining after SpO2 filtering          : %d\n', length(SpO2_final));
fprintf('Artifacts removed                       : %d\n', sum(artifact_idx));
fprintf('Final continuous SpO2 samples           : %d\n', length(SpO2_clean));
fprintf('Final SpO2 min / max / mean             : %.2f / %.2f / %.2f %%\n', ...
   min(SpO2_clean), max(SpO2_clean), mean(SpO2_clean));
disp(' ');
disp('[STAGE 2 - LAYER 1] DESATURATION EVENTS');
fprintf('1 Hz resampled SpO2 samples             : %d\n', length(SpO2_uniform));
fprintf('Baseline window                         : %d sec\n', baseline_window_sec);
fprintf('Desaturation threshold                  : %.1f %%\n', drop_threshold);
fprintf('Min event duration                      : %d sec\n', min_event_duration_sec);
fprintf('Detected desaturation events            : %d\n', num_events);
if num_events > 0
   fprintf('Lowest event SpO2                       : %.2f %%\n', min(event_spo2_min));
   fprintf('Largest drop from baseline              : %.2f %%\n', max(event_drop_max));
else
   fprintf('Lowest event SpO2                       : N/A\n');
   fprintf('Largest drop from baseline              : N/A\n');
end
disp(' ');
disp('[STAGE 3 - LAYER 1] EPOCH CLASSIFICATION');
fprintf('Epoch length                            : %d sec\n', epoch_len_sec);
fprintf('Number of full epochs                   : %d\n', num_epochs);
fprintf('Normal Oxygenation epochs               : %d\n', sum(Label == "Normal Oxygenation"));
fprintf('Desaturation Event epochs               : %d\n', sum(Label == "Desaturation Event"));
fprintf('PoorSignal epochs                       : %d\n', sum(Label == "PoorSignal"));
fprintf('Uncertain epochs                        : %d\n', sum(Label == "Uncertain"));
fprintf('Adaptive variability threshold          : %.2f\n', variability_threshold);
disp(' ');
disp('[STAGE 4 - LAYER 2] CONTEXTUAL OXYGEN FLAGS');
fprintf('Epochs with borderline %.0f-%.0f%% drops      : %d\n', ...
   borderline_drop_low, drop_threshold, sum(HasBorderlineDrop));
fprintf('Epochs with short >%.0f%% drops               : %d\n', ...
